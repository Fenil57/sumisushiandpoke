rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null &&
        firestore.get(
          /databases/(default)/documents/users/$(request.auth.uid)
        ).data.role == 'admin';
    }

    function isAllowedImageType() {
      return request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    function hasAllowedImageExtension(fileName) {
      return fileName.matches('.*\\.(jpg|jpeg|png|webp|JPG|JPEG|PNG|WEBP)');
    }

    function isValidImage(maxSizeInBytes, fileName) {
      return request.resource != null &&
        request.resource.size <= maxSizeInBytes &&
        isAllowedImageType() &&
        hasAllowedImageExtension(fileName);
    }

    match /menu-items/{category}/{itemId}/{fileName} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidImage(5 * 1024 * 1024, fileName);
      allow delete: if isAdmin();
    }

    match /site-assets/{assetType}/{fileName} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidImage(2 * 1024 * 1024, fileName);
      allow delete: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
