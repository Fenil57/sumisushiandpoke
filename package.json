{
  "name": "sumi-sushi",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "server": "tsx watch server.ts",
    "dev:all": "concurrently --names \"frontend,backend\" -c \"cyan,magenta\" \"npm run dev\" \"npm run server\"",
    "build": "vite build",
    "start": "tsx server.ts",
    "preview": "vite preview",
    "seed": "tsx scripts/smartSeed.ts",
    "seed:full": "tsx scripts/seedFullMenu.ts",
    "seed:smart": "tsx scripts/smartSeed.ts",
    "seed:prod": "npx cross-env USE_PROD=true tsx scripts/seedFullMenu.ts",
    "seed:smart:prod": "npx cross-env USE_PROD=true tsx scripts/smartSeed.ts",
    "audit:menu-images": "node scripts/audit-menu-images.cjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "i18next": "^26.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.14.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
