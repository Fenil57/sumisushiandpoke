# ============================================================================
# Sumi Sushi and Poke - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ============================================================================

# ─── FRONTEND FIREBASE CONFIG (Public - Safe to expose) ─────────────────────
# Get these from Firebase Console > Project Settings > Your apps
VITE_FIREBASE_API_KEY="your_firebase_api_key_here"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_sender_id"
VITE_FIREBASE_APP_ID="your_app_id"

# ─── API CONFIGURATION ──────────────────────────────────────────────────────
# Backend API URL (for frontend to connect to)
VITE_API_BASE_URL="http://localhost:3001"

# Your production domain (e.g., https://sumisushi.fi)
# Leave empty for local development
APP_BASE_URL=""

# ─── BACKEND FIREBASE ADMIN (KEEP SECRET!) ─────────────────────────────────
# Generate from Firebase Console > Project Settings > Service Accounts
# Click "Generate new private key"
FIREBASE_ADMIN_PROJECT_ID="your-project-id"
FIREBASE_ADMIN_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── PAYMENT GATEWAY - FLATPAY (KEEP SECRET!) ───────────────────────────────
# Get from your Flatpay/Frisbii merchant dashboard
FLATPAY_PRIVATE_API_KEY="your_flatpay_private_api_key"
FLATPAY_WEBHOOK_USERNAME="your_webhook_username"
FLATPAY_WEBHOOK_PASSWORD="your_secure_webhook_password"

# ─── EMAIL NOTIFICATIONS (KEEP SECRET!) ─────────────────────────────────────
# Gmail SMTP configuration
# To get Gmail App Password:
# 1. Enable 2-Step Verification in Google Account
# 2. Go to Security > 2-Step Verification > App Passwords
# 3. Generate password for "Mail"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your_gmail_app_password_16_chars"
NOTIFICATION_EMAIL="your-email@gmail.com"

# ─── ADMIN ACCESS (KEEP SECRET!) ────────────────────────────────────────────
# Admin dashboard credentials
ADMIN_EMAIL="admin@yourdomain.com"
# Use a strong password (minimum 12 characters, mix of upper/lower/numbers/symbols)
ADMIN_PASSWORD="your_strong_password_here"

# ─── FEATURE FLAGS ──────────────────────────────────────────────────────────
# Enable/disable menu image upload in admin panel
VITE_ENABLE_MENU_IMAGE_UPLOAD="false"

# ─── OPTIONAL: GEOCODING (Not required - using free Nominatim API) ──────────
# If you want to use Finnish National Land Survey API instead:
# Register at: https://locationfinland.fi/finland/lihp/getapikey
# NLS_API_KEY="your_nls_api_key"

# ============================================================================
# SECURITY CHECKLIST:
# ☐ Copy this file: cp .env.example .env
# ☐ Fill in all required values
# ☐ Never commit .env to git
# ☐ Use strong passwords (12+ characters)
# ☐ Rotate secrets if accidentally exposed
# ☐ Enable 2FA on all service accounts
# ============================================================================
